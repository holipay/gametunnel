# 所有文本文件统一用 LF
* text=auto eol=lf

# 特定格式强制 LF
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.go text eol=lf
*.c text eol=lf
*.h text eol=lf
*.java text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.css text eol=lf

# 二进制文件不处理
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.zip binary
*.tar.gz binary
*.exe binary
*.dll binary
*.so binary
*.woff binary
*.woff2 binary
*.ttf binary
